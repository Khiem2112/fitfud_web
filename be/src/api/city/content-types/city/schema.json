{
  "kind": "collectionType",
  "collectionName": "cities",
  "info": {
    "singularName": "city",
    "pluralName": "cities",
    "displayName": "City",
    "description": "Top-level geographic unit (province / city)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "districts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::district.district",
      "mappedBy": "city"
    }
  }
}